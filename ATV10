            <!-- MURAL DE COMUNICAÇÃO DA EQUIPE -->
            <div class="card-saudacao">
                <div class="card-titulo" style="color: var(--magenta);">👋 Mural da Equipe</div>
                <p>📢 "Olá, equipe! Sejam bem-vindos a mais um ciclo de desenvolvimento incrível. Vamos juntos construir soluções memoráveis!"</p>
            </div>

            <!-- COMPONENTE DE TERMINAL PROFISSIONAL -->
            <div class="terminal-container">
                <div class="terminal-header">
                    <div class="terminal-buttons">
                        <div class="btn-term btn-fechar"></div>
                        <div class="btn-term btn-minimizar"></div>
                        <div class="btn-term btn-maximizar"></div>
                    </div>
                    <div class="terminal-titulo">bash - node app.js</div>
                </div>
                <!-- O Javascript vai injetar os logs estilizados aqui dentro -->
                <div class="terminal-content" id="terminal-log"></div>
            </div>

        </div>

        <!-- FOOTER DO SITE -->
        <footer class="dashboard-footer">
            Desenvolvido com excelência visual • <a href="https://github.com" target="_blank">Acessar perfil no GitHub</a>
        </footer>
    </div>

    <!-- ==========================================================================
         LÓGICA JAVASCRIPT INTEGRADA (Roda as funções solicitadas e imprime na tela)
         ========================================================================== -->
