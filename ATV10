                    <div class="card-conteudo" id="nome-dev">Seu Nome Aqui</div>
                </div>
                <div class="card">
                    <div class="card-titulo">📁 Ambiente Atual</div>
                    <div class="card-conteudo" style="color: var(--cyan);">Production / Node.js Cluster</div>
                </div>
